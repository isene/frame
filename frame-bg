#!/bin/bash
# frame-bg <image> — set the frame (asm X server) desktop wallpaper.
#
# frame ships no image decoder (that would mean a zlib/PNG stack in the
# 50k-line server), so this pre-renders <image> to a raw BGRX buffer at panel
# resolution — ~/.framebg — which ~/.framerc points at via
#   background = /home/geir/.framebg
# frame mmaps that raw once and blits it as the compositor background (no feh,
# no per-frame decode). Re-run after changing the image or the panel res, then
# restart frame (or start a fresh frt session) to apply.
set -e
img="${1:?usage: frame-bg <image>}"
[ -r "$img" ] || { echo "frame-bg: not readable: $img" >&2; exit 1; }

# Panel res: ask a running frame, else default to this laptop's panel.
dim=$(xdpyinfo 2>/dev/null | awk '/dimensions:/{print $2; exit}')
: "${dim:=1920x1200}"
w=${dim%x*}; h=${dim#*x}
out="$HOME/.framebg"

# bg-fill semantics (match feh --bg-fill): scale to cover, centre-crop.
convert "$img" -resize "${w}x${h}^" -gravity center -extent "${w}x${h}" "bgra:$out"
echo "frame-bg: wrote $out ($(stat -c %s "$out") bytes, ${w}x${h})"

rc="$HOME/.framerc"
if ! grep -q '^[[:space:]]*background[[:space:]]*=' "$rc" 2>/dev/null; then
    printf 'background = %s\n' "$out" >> "$rc"
    echo "frame-bg: added 'background = $out' to $rc"
fi
echo "frame-bg: restart frame (Mod4+Shift+x won't reload it — start a fresh frt) to apply."
